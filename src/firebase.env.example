# ============================================================
#  HOW TO CONNECT YOUR FIREBASE PROJECT
# ============================================================
#
# 1. Go to https://console.firebase.google.com
# 2. Create project: "civicsense-trustgrid"
# 3. Enable these services:
#    - Authentication → Email/Password
#    - Firestore Database → Start in test mode
#    - Storage → Start in test mode
#
# 4. Go to Project Settings → Your Apps → Add Web App
# 5. Copy the config and paste into src/firebase.js
#
# 6. Firestore Rules (Security):
#    rules_version = '2';
#    service cloud.firestore {
#      match /databases/{database}/documents {
#        match /issues/{id} {
#          allow read: if true;
#          allow write: if request.auth != null;
#        }
#        match /projects/{id} {
#          allow read: if true;
#          allow write: if request.auth.token.role == 'admin';
#        }
#        match /users/{id} {
#          allow read, write: if request.auth != null;
#        }
#      }
#    }
#
# 7. Storage Rules:
#    rules_version = '2';
#    service firebase.storage {
#      match /b/{bucket}/o {
#        match /issues/{allPaths=**} {
#          allow read: if true;
#          allow write: if request.auth != null;
#        }
#      }
#    }
#
# 8. Create these test users in Authentication:
#    ananya@civicsense.in / citizen123   (Citizen)
#    admin@pmc.gov.in / admin123         (Gov Admin)
#
# NOTE: Without Firebase config, the app uses LOCAL MODE
#       (in-memory state, no persistence). Everything still works!
